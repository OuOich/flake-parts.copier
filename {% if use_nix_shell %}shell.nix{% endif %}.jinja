{
  pkgs ? import <nixpkgs> { },
  ...
}:

pkgs.mkShell rec {
  packages = with pkgs; [
    hello
  ];

  shellHook = /* bash */ ''
    echo

    echo -n -e "\033[35m"
    echo "    ฅ(^•ﻌ•^ฅ)                         NIX SHELL LOADED"
    echo "    --------------------------------------------------"
    echo -n -e "\033[0m"

    echo

    echo -e "\033[32m\033[1mShell Packages:\033[0m"
    echo -n -e "\033[36m"
    echo "${
      if packages == [ ] then
        "(none)"
      else
        pkgs.lib.concatMapStringsSep " " (p: p.pname or p.name) packages
    }" | xargs -n 10 | sed 's/^/    /'
    echo -n -e "\033[0m"

    echo
  '';
}
